# FUB-GHL MCP Bridge - Environment Configuration
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env or .env.local to version control

# Follow Up Boss API Credentials
# Get these from: https://app.followupboss.com/settings/integrations
FUB_API_KEY=your_fub_api_key_here
FUB_X_SYSTEM=your_fub_x_system_header_value_here
FUB_X_SYSTEM_KEY=your_fub_x_system_key_header_value_here

# GoHighLevel API Credentials
# Get these from: https://app.gohighlevel.com/settings/integrations/api
GHL_PRIVATE_TOKEN=your_ghl_private_token_here
GHL_LOCATION_ID=your_ghl_location_id_here

# MCP Server Configuration (Optional)
# Default: 100 requests per 60 seconds
RATE_LIMIT_REQUESTS=100

# Rate limit window in seconds
# Default: 60 seconds
RATE_LIMIT_WINDOW=60

# Request timeout in milliseconds
# Default: 15000 (15 seconds)
REQUEST_TIMEOUT=15000

# Logging level
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Monitoring Configuration (Optional, for monitoring script)
# The URL of your deployed Cloudflare Worker
WORKER_URL=https://fub-ghl-mcp-bridge.example.workers.dev

# Check interval for monitoring (in milliseconds)
# Default: 30000 (30 seconds)
CHECK_INTERVAL=30000

# Slack webhook URL for alerts (optional)
# If set, alerts will be sent to Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Testing Configuration (Optional)
# Test email for search_fub_person tests
TEST_EMAIL=test@example.com

# Test phone for search_fub_person tests
TEST_PHONE=+1-555-123-4567
