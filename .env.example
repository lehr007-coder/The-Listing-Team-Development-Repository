# ============================================================
# Blog Automation Tool - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys
# ============================================================

# --- Anthropic (Claude) API Key ---
# Used for content spinning and SEO optimization
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Squarespace API Key ---
# Used to publish blog posts to your Squarespace site
# How to get it:
#   1. Log into Squarespace
#   2. Go to Settings > Developer API Keys
#   3. Click "Generate API Key"
#   4. Copy the key
SQUARESPACE_API_KEY=your-squarespace-api-key-here

# Your Squarespace Site ID (found in Settings > General > Site ID)
SQUARESPACE_SITE_ID=your-site-id-here

# Your Squarespace Blog Collection ID
# To find: Go to your blog page in Squarespace, the collection ID is in the URL
# Or use the API: GET /1.0/commerce/inventory  to list collections
SQUARESPACE_BLOG_COLLECTION_ID=your-blog-collection-id-here

# --- Go High Level API Key ---
# Used to publish blog posts to your GHL site
# How to get it:
#   1. Log into Go High Level
#   2. Go to Settings > Business Profile > API Keys (or Company Settings > API)
#   3. Generate a new API key with blog/post permissions
GHL_API_KEY=your-ghl-api-key-here

# Your Go High Level Location ID
GHL_LOCATION_ID=your-location-id-here

# Your Go High Level Blog ID (optional - will use default blog if not set)
GHL_BLOG_ID=your-blog-id-here
